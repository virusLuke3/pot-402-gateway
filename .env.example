# POT-402 Gateway safe defaults
POT402_PORT=4020
# Supported modes: mock, local-dev. Unknown values fall back to mock.
POT402_MODE=mock
# Mainnet RPC is used only for read-only status/config checks.
POT402_RPC=wss://mainnet.portaldot.io
# Local-dev mode is restricted to localhost RPC endpoints.
POT402_LOCAL_RPC=ws://127.0.0.1:9944
# Demo recipient only. Replace before public-chain transactions. Never commit private keys.
POT402_RECIPIENT=5E9oDs9PjpsBbxXxRE9uMaZZhnBAV38n2ouLB28oecBDdeQo
